# ═══════════════════════════════════════════════════════════
# AntrenmanAI — .gitignore
# ═══════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environment ──────────────────────────────────
venv/
.venv/
env/

# ── Environment Variables ────────────────────────────────
.env
.env.local
.env.*.local

# ── SQLite Database ──────────────────────────────────────
*.db
*.sqlite3

# ── Node / Frontend ─────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/

# ── IDE / Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Cache ────────────────────────────────────────────────
.cache/
*.log
.pytest_cache/

# ── HuggingFace / Model Cache ───────────────────────────
models/
*.bin
*.safetensors
