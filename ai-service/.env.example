# ─── OpenAI API (Tüm AI görevleri) ──────────────────────────────────
EXTERNAL_API_KEY=sk-proj-your-openai-api-key-here
EXTERNAL_API_BASE_URL=https://api.openai.com/v1
EXTERNAL_MODEL_NAME=gpt-4o-mini

# ─── Google OAuth ────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Boş bırakırsan dev mode aktif olur (otomatik giriş)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRE_HOURS=24

# ─── Sunucu Ayarları ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── CORS (Production) ──────────────────────────────────────────────
# Vercel domain'ini ekle (virgülle ayır)
# CORS_ORIGINS=https://antrenmanai.vercel.app,https://antrenman.ai
